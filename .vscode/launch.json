{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug FDTD_1D_OOP_Solver",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build_debug/FDTD_1D_OOP_Solver",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "cmake build debug",
      "setupCommands": [
        {
          "description": "Enable pretty-printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        }
      ]
    },
    {
      "name": "Release FDTD_1D_OOP_Solver",
      "type": "cppdbg",
