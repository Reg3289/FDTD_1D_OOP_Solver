{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake build debug",
      "type": "shell",
      "command": "cmake --build build_debug -j",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "cmake build release",
      "type": "shell",
      "command": "cmake --build build_release -j",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}